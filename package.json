{
  "name": "pm3",
  "version": "1.0.0",
  "description": "Proxmark3 Card Clone Tool",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "vite build && electron-builder --config electron-builder.json",
    "package:mac": "vite build && electron-builder --mac --config electron-builder.json",
    "package:win": "vite build && electron-builder --win --config electron-builder.json",
    "package:linux": "vite build && electron-builder --linux --config electron-builder.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
